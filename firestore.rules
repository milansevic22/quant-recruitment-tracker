rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /companies/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /jobs/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /scanRuns/{document} {
      allow read: if true;
      allow write: if false;
    }
  }
}
